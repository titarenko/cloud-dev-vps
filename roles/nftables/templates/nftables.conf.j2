#!/usr/sbin/nft -f

flush ruleset

table inet filter {
  # Temporary SSH brute-force block lists (auto-expire after 15 minutes)
  set ssh_brute4 {
    type ipv4_addr
    flags dynamic, timeout
    timeout 15m
  }

  set ssh_brute6 {
    type ipv6_addr
    flags dynamic, timeout
    timeout 15m
  }

  chain input {
    type filter hook input priority 0; policy drop;

    ct state established,related accept
    iif lo accept
    ip protocol icmp accept
    ip6 nexthdr icmpv6 accept

    # Drop IPs already banned for excessive SSH attempts
    ip saddr @ssh_brute4 drop
    ip6 saddr @ssh_brute6 drop

    # New SSH connections: ban source IP for 15m if over 15/min (burst 30)
    tcp dport 22 ct state new add @ssh_brute4 { ip saddr limit rate over 15/minute burst 30 packets } drop
    tcp dport 22 ct state new add @ssh_brute6 { ip6 saddr limit rate over 15/minute burst 30 packets } drop

    tcp dport 22 accept
  }

  chain forward {
    type filter hook forward priority 0; policy drop;
  }

  chain output {
    type filter hook output priority 0; policy accept;
  }
}

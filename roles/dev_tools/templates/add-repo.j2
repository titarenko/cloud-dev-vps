#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: add-repo <repo-name>" >&2
  exit 1
fi

REPO="$1"
USERNAME="{{ github_username }}"
KEY_PATH="$HOME/.ssh/deploy_${REPO}"

ssh-keygen -t ed25519 -C "deploy@${REPO}" -f "$KEY_PATH" -N ""

cat >> ~/.ssh/config <<EOF

Host github-${REPO}
  HostName github.com
  User git
  IdentityFile ${KEY_PATH}
  IdentitiesOnly yes
EOF

chmod 600 ~/.ssh/config

echo
echo "Add this deploy key to: https://github.com/${USERNAME}/${REPO}/settings/keys"
echo
cat "${KEY_PATH}.pub"
echo
read -rp "Press Enter once you've added the key to GitHub..."

git clone "git@github-${REPO}:${USERNAME}/${REPO}.git"
echo "Cloned into ./${REPO}"
